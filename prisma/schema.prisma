// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  ADMIN
  AGENT
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransactionType {
  RIDE
  TOPUP
  REFUND
}

enum TerminalStatus {
  ONLINE
  OFFLINE
  LOCKED
}

model User {
  id           String   @id @default(uuid())
  firstname    String
  lastname     String
  email        String   @unique
  matricNumber String   @unique @db.VarChar(20)
  password     String
  role         Role     @default(STUDENT)
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  wallet       Wallet?
  transactions Transaction[]
  kyc          Kyc?

  @@map("users")
}

model Wallet {
  id          String   @id @default(uuid())
  balance     Decimal  @default(0) @db.Decimal(10, 2)
  is_linked   Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @updatedAt @db.Timestamptz(6)

  // Linked via matricNumber for hardware terminal speed
  student_uid String   @unique @db.VarChar(20)
  user        User     @relation(fields: [student_uid], references: [matricNumber])

  @@map("wallets")
}

model Terminal {
  terminal_id       String         @id @db.VarChar(20)
  status            TerminalStatus @default(OFFLINE)  // ✅ Enum — no more raw strings
  last_seen         DateTime?      @db.Timestamptz(6)
  active_driver_uid String?        @db.VarChar(20)
  secret_key        String         @db.VarChar(64)

  transactions Transaction[]

  @@map("terminals")
}

model Transaction {
  transaction_id   String          @id @db.VarChar(64)
  type             TransactionType @default(RIDE)      // ✅ Enum — enforced at DB level
  terminal_id      String          @db.VarChar(20)
  student_uid      String          @db.VarChar(20)
  amount           Decimal         @db.Decimal(10, 2)
  driver_uid       String?         @db.VarChar(20)
  synced_at        DateTime        @default(now()) @db.Timestamptz(6)

  user             User     @relation(fields: [student_uid], references: [matricNumber])
  terminal         Terminal @relation(fields: [terminal_id], references: [terminal_id])

  @@map("transactions")
}

model Kyc {
  id              String    @id @default(uuid())
  studentName     String
  studentId       String    @unique   // ✅ No two students should share a student ID
  matricNumber    String              // Validated against User.matricNumber in kyc.service.js
  school         String
  department      String
  idCardImageUrl  String
  faceImageUrl    String?
  status          KycStatus @default(PENDING)
  rejectionReason String?
  submittedAt     DateTime  @default(now())
  reviewedAt      DateTime?

  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("kyc_records")
}