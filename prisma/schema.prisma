// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_POOLED") // Use fully for runtime
  directUrl = env("DATABASE_URL") // Use for migrations only
}

enum Role {
  STUDENT
  ADMIN
  AGENT
  DRIVER
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransactionType {
  RIDE
  TOPUP
  REFUND
}

enum TerminalStatus {
  ONLINE
  OFFLINE
  LOCKED
}

// Agent account lifecycle — SUSPENDED = temporary, DEACTIVATED = permanent
enum AgentStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

// Dispute lifecycle — UNDER_REVIEW means an agent/admin has picked it up
enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

model User {
  id           String   @id @default(uuid())
  firstname    String
  lastname     String
  email        String   @unique
  matricNumber String   @unique @db.VarChar(20)
  password     String
  role         Role     @default(STUDENT)
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  wallet       Wallet?
  transactions Transaction[]
  kyc          Kyc?

  // ✅ Agents created by this admin (empty for non-admins)
  createdAgents     Agent[]        @relation("AdminCreatedAgents")
  // ✅ Notifications sent to this student (via matricNumber)
  notifications     Notification[]
  // ✅ Disputes raised by this student
  studentDisputes   Dispute[]      @relation("StudentDisputes")
  // ✅ Disputes resolved by this admin
  resolvedDisputes  Dispute[]      @relation("AdminResolvedDisputes")

  // ✅ Composite index — driver login does findFirst({ where: { matricNumber, role: DRIVER } })
  // ✅ Admin queries filter by role + isVerified frequently
  @@index([role, isVerified])

  @@map("users")
}

model Wallet {
  id          String   @id @default(uuid())
  balance     Decimal  @default(0) @db.Decimal(10, 2)
  is_linked   Boolean  @default(false)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @updatedAt @db.Timestamptz(6)

  // Linked via matricNumber for hardware terminal speed
  student_uid String   @unique @db.VarChar(20)
  user        User     @relation(fields: [student_uid], references: [matricNumber])

  // ✅ Index on is_linked — full sync queries findMany({ where: { is_linked: true } })
  // Without this, every SYS:REQ_FULL_SYNC scans the entire wallets table
  @@index([is_linked])

  @@map("wallets")
}

model Terminal {
  terminal_id       String         @id @db.VarChar(20)
  status            TerminalStatus @default(OFFLINE)
  last_seen         DateTime?      @db.Timestamptz(6)
  active_driver_uid String?        @db.VarChar(20)
  secret_key        String         @db.VarChar(64)

  transactions Transaction[]

  // ✅ Index on status — broadcastDeltaToFleet does findMany({ where: { status: ONLINE } })
  // Runs on every blacklist/whitelist update — must be fast
  @@index([status])

  @@map("terminals")
}

model Transaction {
  transaction_id   String          @id @db.VarChar(64)
  type             TransactionType @default(RIDE)
  terminal_id      String          @db.VarChar(20)
  student_uid      String          @db.VarChar(20)
  amount           Decimal         @db.Decimal(10, 2)
  driver_uid       String?         @db.VarChar(20)
  synced_at        DateTime        @default(now()) @db.Timestamptz(6)

  user             User     @relation(fields: [student_uid], references: [matricNumber])
  terminal         Terminal @relation(fields: [terminal_id], references: [terminal_id])
  // ✅ A transaction can have disputes raised against it
  disputes         Dispute[]

  @@index([student_uid, synced_at(sort: Desc)])
  @@index([terminal_id, synced_at(sort: Desc)])
  @@index([type])
  // ✅ New — income stats by driver: findMany({ where: { driver_uid, type: RIDE }, orderBy: { synced_at: 'desc' } })
  @@index([driver_uid, synced_at(sort: Desc)])

  @@map("transactions")
}

model Kyc {
  id              String    @id @default(uuid())
  studentName     String
  studentId       String    @unique
  matricNumber    String
  school          String
  department      String
  phoneNumber     String
  idCardImageUrl  String
  faceImageUrl    String?
  status          KycStatus @default(PENDING)
  rejectionReason String?
  submittedAt     DateTime  @default(now())
  reviewedAt      DateTime?

  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Existing index kept — admin KYC queue filters by status
  @@index([status])

  // ✅ New composite index — admin searches pending KYC sorted by submission date
  // Query: findMany({ where: { status: PENDING }, orderBy: { submittedAt: 'asc' } })
  @@index([status, submittedAt(sort: Asc)])

  @@map("kyc_records")
}

model Blacklist {
  id            String   @id @default(uuid())
  student_uid   String   @unique @db.VarChar(20)  // matricNumber
  reason        String   @default("LOW_BALANCE")
  blacklistedAt DateTime @default(now())

  // ✅ Index on blacklistedAt — admin views recently blacklisted students
  @@index([blacklistedAt(sort: Desc)])

  @@map("blacklist")
}

model CardMapping {
  id          String   @id @default(uuid())
  card_uid    String   @unique @db.VarChar(20)  // Hardware UID e.g. 238DB4E8
  student_uid String   @unique @db.VarChar(20)  // matricNumber e.g. 2022/1/87453LH
  linked_at   DateTime @default(now())

  // ✅ Index on linked_at — admin can view recently registered cards
  @@index([linked_at(sort: Desc)])

  @@map("card_mappings")
}

// ─────────────────────────────────────────────
// AGENT
// Separate table — agents have no matricNumber
// and are not students, drivers, or admins.
// ─────────────────────────────────────────────
model Agent {
  id        String      @id @default(uuid())
  firstname String
  lastname  String
  email     String      @unique
  phone     String      @db.VarChar(15)
  password  String      // bcrypt hashed

  // SUSPENDED = temporary block, DEACTIVATED = permanent removal
  // Both states are checked by checkAgentActive middleware
  status    AgentStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // FK → User.id — the ADMIN User who registered this agent
  // Restricted delete: admin cannot be deleted while agents exist under them
  createdBy String
  creator   User    @relation("AdminCreatedAgents", fields: [createdBy], references: [id])

  // Disputes this agent has resolved
  resolvedDisputes Dispute[] @relation("AgentResolvedDisputes")

  // ✅ status index — checkAgentActive middleware + admin agent list filter
  @@index([status])

  // ✅ Composite — admin fetches agents they created, filtered by status
  // findMany({ where: { createdBy, status: ACTIVE } })
  @@index([createdBy, status])

  @@map("agents")
}

// ─────────────────────────────────────────────
// NOTIFICATION
// Sent by admin/agents to individual students
// ─────────────────────────────────────────────
model Notification {
  id        String   @id @default(uuid())
  title     String
  body      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // FK → User.matricNumber — consistent with Wallet + Blacklist pattern
  student_uid String @db.VarChar(20)
  user        User   @relation(fields: [student_uid], references: [matricNumber], onDelete: Cascade)

  // ✅ Primary feed query: findMany({ where: { student_uid }, orderBy: { createdAt: 'desc' } })
  @@index([student_uid, createdAt(sort: Desc)])

  // ✅ Unread badge count: count({ where: { student_uid, isRead: false } })
  @@index([student_uid, isRead])

  @@map("notifications")
}

// ─────────────────────────────────────────────
// DISPUTE
// Raised against a Transaction by a student.
// Resolved by either an Agent or an Admin.
// Polymorphic resolution handled via two
// nullable FKs (not a plain string) to keep
// referential integrity enforced at DB level.
// ─────────────────────────────────────────────
model Dispute {
  id          String        @id @default(uuid())
  description String        // Student's account of what went wrong
  status      DisputeStatus @default(OPEN)
  resolution  String?       // Agent/admin notes on how it was closed
  resolvedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The student who raised this dispute (FK → User.matricNumber)
  student_uid String @db.VarChar(20)
  user        User   @relation("StudentDisputes", fields: [student_uid], references: [matricNumber], onDelete: Cascade)

  // The transaction being disputed (FK → Transaction.transaction_id)
  // One transaction can have multiple disputes (e.g. re-raised after rejection)
  transaction_id String      @db.VarChar(64)
  transaction    Transaction @relation(fields: [transaction_id], references: [transaction_id])

  // Resolver: exactly one of these will be set when status moves to RESOLVED/REJECTED
  // Enforced at service layer — Prisma does not support check constraints natively
  resolvedByAgent String?
  agent           Agent? @relation("AgentResolvedDisputes", fields: [resolvedByAgent], references: [id])

  resolvedByAdmin String?
  admin           User?  @relation("AdminResolvedDisputes", fields: [resolvedByAdmin], references: [id])

  // ✅ Dispute queue: admin/agent sees oldest open disputes first
  // findMany({ where: { status: OPEN }, orderBy: { createdAt: 'asc' } })
  @@index([status, createdAt(sort: Asc)])

  // ✅ Student dispute history lookup
  @@index([student_uid, createdAt(sort: Desc)])

  // ✅ Link back from a specific transaction — check if a transaction has disputes
  @@index([transaction_id])

  @@map("disputes")
}